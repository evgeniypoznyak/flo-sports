## DTOs & Validation

- 🔴 **Always use DTOs** for request/response contracts
- 🔴 **Implement class-validator decorators** for all inputs
- 🟠 **Separate CreateDTO from UpdateDTO** - Different validation rules
- 🟠 **Use custom validators** for complex validation logic
- 🟡 **Document DTO properties** with JSDoc comments
- 🔴 **Never expose entity properties** that shouldn't be visible to clients

```typescript
// ✅ GOOD: Properly validated DTO
export class CreateUserDto {
  @ApiProperty({ description: 'User email address' })
  @IsEmail()
  @IsNotEmpty()
  email: string;

  @ApiProperty({ description: 'User full name' })
  @IsString()
  @MinLength(2)
  @MaxLength(100)
  @IsNotEmpty()
  name: string;

  @ApiProperty({ description: 'User password' })
  @IsString()
  @MinLength(8)
  @Matches(/^(?=.*[A-Za-z])(?=.*\d)/, {
    message: 'Password must contain letters and numbers'
  })
  @IsNotEmpty()
  password: string;
}

export class UpdateUserDto {
  @ApiProperty({ description: 'User full name', required: false })
  @IsString()
  @MinLength(2)
  @MaxLength(100)
  @IsOptional()
  name?: string;

  @ApiProperty({ description: 'User phone', required: false })
  @IsString()
  @Matches(/^[\+]?[(]?[0-9]{3}[)]?[-\s\.]?[0-9]{3}[-\s\.]?[0-9]{4,6}$/)
  @IsOptional()
  phone?: string;
}

export class UserResponse {
  @ApiProperty()
  id: number;

  @ApiProperty()
  email: string;

  @ApiProperty()
  name: string;

  @ApiProperty()
  createdAt: Date;

  @ApiProperty()
  updatedAt: Date;
}

// ❌ BAD: No validation, mixing concerns
export class UserDto {
  email: any;
  password: any;
  name: any;
  isAdmin: boolean;
  internalId: string;
}
```

