## Services & Business Logic

- 🔴 **Keep services focused** - One service = one responsibility
- 🟠 **Use dependency injection** for all dependencies (repositories, external services)
- 🔴 **Never mix concerns** - Separate business logic, data access, and external integrations
- 🟠 **Implement error handling** with custom exceptions
- 🟡 **Use interfaces** to define service contracts
- 🔴 **Make services testable** - Avoid direct instantiation of dependencies

```typescript
// ✅ GOOD: Clean service with single responsibility
@Injectable()
export class UsersService {
  constructor(
    private readonly usersRepository: UsersRepository,
    private readonly passwordService: PasswordService,
    private readonly emailService: EmailService,
    private readonly logger: Logger
  ) {}

  async create(createUserDto: CreateUserDto): Promise<User> {
    const existingUser = await this.usersRepository.findByEmail(
      createUserDto.email
    );
    if (existingUser) {
      throw new BadRequestException('User with this email already exists');
    }

    const hashedPassword = await this.passwordService.hash(
      createUserDto.password
    );

    const user = await this.usersRepository.create({
      ...createUserDto,
      password: hashedPassword
    });

    this.logger.log(`User created: ${user.id}`);
    await this.emailService.sendWelcomeEmail(user.email);

    return user;
  }

  async findById(id: number): Promise<User | null> {
    return this.usersRepository.findById(id);
  }

  async update(id: number, updateUserDto: UpdateUserDto): Promise<User> {
    const user = await this.findById(id);
    if (!user) {
      throw new NotFoundException(`User with ID ${id} not found`);
    }

    return this.usersRepository.update(id, updateUserDto);
  }

  async remove(id: number): Promise<void> {
    const user = await this.findById(id);
    if (!user) {
      throw new NotFoundException(`User with ID ${id} not found`);
    }

    await this.usersRepository.remove(id);
    this.logger.log(`User deleted: ${id}`);
  }
}

// ❌ BAD: Service with mixed concerns
@Injectable()
export class UsersService {
  constructor(private db: Database) {}

  async create(body: any) {
    // Password hashing mixed with business logic
    body.password = await bcrypt.hash(body.password, 10);
    
    // Email validation mixed in
    if (!body.email.includes('@')) throw new Error('Invalid email');
    
    // HTTP response building (wrong layer)
    const result = {
      id: body.id,
      statusCode: 201,
      message: 'Created'
    };
    
    return result;
  }
}
```

